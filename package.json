{
  "name": "muso-dojo-next",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "private": false,
  "type": "module",
  "scripts": {
    "start": "next start",
    "lint": "eslint -c eslint.config.mjs",
    "lint:fix": "eslint -c eslint.config.mjs --fix",
    "lint:strict": "eslint -c eslint.strict.config.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "validate": "pnpm lint && pnpm check",
    "validate:strict": "pnpm validate && pnpm lint:strict",
    "clean": "rm -rf .next",
    "dev": "concurrently -p none 'serwist build --watch' 'next dev'",
    "dev:once": "cross-env NODE_ENV=development serwist build && next dev",
    "build": "next build && serwist build",
    "preview": "pnpm build && next start"
  },
  "dependencies": {
    "@musodojo/music-theory-data": "^32.0.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@serwist/cli": "^9.5.11",
    "@serwist/next": "^9.5.11",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.3",
    "serwist": "^9.5.11",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
